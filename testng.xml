<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    parallel="methods" + thread-count="2" lets independent test methods (including
    @DataProvider invocations) run concurrently. Each method gets its own browser
    instance via DriverFactory's ThreadLocal, so there is no shared state.
-->
<suite name="Twitch UI Automation Suite" verbose="1" parallel="methods" thread-count="2">

    <test name="Twitch Search Tests">
        <classes>
            <class name="com.automation.twitch.tests.TwitchSearchTest"/>
        </classes>
    </test>

</suite>
